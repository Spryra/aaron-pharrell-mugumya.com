# === Database ===
DATABASE_URL=postgresql://user:password@host:5432/database

# === Authentication ===
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# === Admin Credentials ===
# Email for admin login and receiving contact form submissions
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-password-here

# === Cloudinary (Image Storage) ===
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# === Upstash Redis (Caching & Rate Limiting) ===
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# === Email Service ===
RESEND_API_KEY=your-resend-key
# Receives contact form submissions (same as ADMIN_EMAIL)
ADMIN_EMAIL_RECIPIENT=your-admin-email@example.com
# Email sender address (must be verified with Resend)
RESEND_FROM_EMAIL=noreply@aaronpharrell.com
# Public contact email displayed on contact page
NEXT_PUBLIC_CONTACT_EMAIL=aaronmugumya04@gmail.com

# === Website URL ===
# Website URL for social sharing and metadata
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# === GitHub ===
GITHUB_REPO_URL=https://github.com/Spryra/aaron-pharrell-mugumya.com
